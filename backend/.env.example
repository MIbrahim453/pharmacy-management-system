# SERVER
NODE_ENV=production
PORT=3000

# FRONTEND
FRONTEND_URL=https://your-frontend-domain.com

# DATABASE
DB_NAME=pharmacy_management_system
# Prefer a least-privileged DB user and TLS-enabled connection in production
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-url>/<db_name>?retryWrites=true&w=majority
MAX_POOL_SIZE=20
MIN_POOL_SIZE=1

# JWT
# Generate long random secrets (at least 32+ bytes) and rotate periodically.
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET_EXPIRES_IN=7d
JWT_REFRESH_SECRET_EXPIRES_IN_REMEMBER_ME=30d

# LOGGING
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# EMAIL
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=527
EMAIL_FROM=no-reply@your-domain.com
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password

# CRON
# Expiry check job schedule (defaults to midnight "0 0 * * *")
EXPIRY_CHECK_CRON=0 0 * * *
# Timezone in which the cron job should trigger (e.g. "Asia/Karachi", "UTC")
CRON_TIMEZONE=Asia/Karachi

